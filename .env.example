# Primeiro teste: true. Depois de testar, troque para false no Render.
DRY_RUN=true

# false = monitora somente os grupos em GROUP_IDS
# true = monitora todos os grupos onde o bot estiver
MONITOR_ALL_GROUPS=false

# Cole aqui o ID do grupo. Exemplo: 120363000000000000@g.us
# Para vários grupos, separe por vírgula.
GROUP_IDS=COLE_AQUI_O_ID_DO_GRUPO

# true = qualquer link fora da lista branca remove o participante
STRICT_LINK_MODE=true

# false = não remove admins, mesmo se mandarem link suspeito
PUNISH_ADMINS=false

# Enviar aviso no grupo depois de remover/apagar?
SEND_GROUP_NOTICE=true

# Local onde a sessão do WhatsApp será salva.
# Local: deixe vazio ou use ./.wwebjs_auth
# Render com Persistent Disk: use /data/.wwebjs_auth
SESSION_PATH=./.wwebjs_auth

# Onde salvar logs.
# Local: ./logs
# Render com Persistent Disk: /data/logs
LOG_DIR=./logs

# Adicione domínios permitidos extras separados por vírgula
EXTRA_ALLOWED_DOMAINS=

# Adicione palavras proibidas extras separadas por vírgula
EXTRA_BANNED_WORDS=

# Adicione domínios proibidos extras separados por vírgula
EXTRA_BANNED_DOMAINS=
